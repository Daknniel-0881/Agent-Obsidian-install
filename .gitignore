# 系统生成
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# 安装日志（用户本地，不入库）
*.log
.codepilot-bootstrap/
logs/

# 编辑器
.vscode/
.idea/
*.iml

# 临时文件
*.tmp
*.bak
*.orig

# 依赖
node_modules/

# 凭证（红线 29 - 绝不能进公开仓库）
.env
.env.*
secrets.json
credentials.json
*.key
*.pem
config.local.*

# 构建产物
dist/
build/
out/

# 测试快照
*.snap.failed

# 用户私有 vault 内容（万一拷错位置）
00-Inbox/
01-Projects/
02-Areas/
03-Resources/
04-Concepts/
05-Archive/
.obsidian/

# 内部 Agent 状态（oh-my-claudecode session/state 不入库）
.omc/
.claude-mem/
.claude/sessions/
.claude/state/

# 大文件不入库（GitHub Release 单独挂载，超过 100MB 不进 git）
*.dmg
*.exe
*.msi
*.deb
*.rpm
*.AppImage
*.pkg
*.tgz
*.zip
*.tar.gz

# 分发包大文件子目录
Mac系统/*.dmg
Win系统/*.exe
Linux系统/*.deb
离线安装包/macos/*.pkg
离线安装包/windows/*.exe
离线安装包/windows/*.msi
离线安装包/npm/*.tgz
