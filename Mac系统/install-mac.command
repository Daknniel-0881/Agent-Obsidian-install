#!/bin/bash
# =============================================================================
# install-mac.command · Mac 双击入口
# =============================================================================
# 客户双击此文件即触发安装流程，自动定位脚本目录并调用 ../scripts/install-macos.sh。
# 装完后保持终端不关闭，让客户能看到完整日志和待办清单。
# =============================================================================

# 切到脚本所在目录（双击时 PWD 会变，需要主动切回）
cd "$(dirname "$0")" || exit 1

# 解锁 quarantine 隔离属性（避免 Gatekeeper 拦截 .sh 子脚本）
# 解锁整个分发目录（自动部署脚本/）下所有文件
xattr -dr com.apple.quarantine "$(cd .. && pwd)" 2>/dev/null || true

# 透传所有命令行参数给主脚本（如 --offline / --pkg-dir）
# 主脚本位于上一层 scripts/ 目录
bash ../scripts/install-macos.sh "$@"
INSTALL_EXIT=$?

# 安装结束后保留终端窗口，让客户看完日志再关闭
echo ""
echo "==============================================="
if [ $INSTALL_EXIT -eq 0 ]; then
    echo "  ✓ 安装流程结束（退出码 0）"
else
    echo "  ✗ 安装中断（退出码 $INSTALL_EXIT）"
    echo "  请查看上方红色错误信息，对照【安装失败常见问题.txt】"
fi
echo "==============================================="
echo ""
read -n 1 -s -r -p "按任意键关闭此窗口..."
echo ""
exit $INSTALL_EXIT
